rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile pictures - users can upload their own
    match /profile_pictures/{userId}_{timestamp}.jpg {
      // Allow authenticated users to read any profile picture
      allow read: if request.auth != null;

      // Allow users to upload/update their own profile pictures
      allow write: if request.auth != null &&
                      userId == request.auth.uid &&
                      request.resource.size < 5 * 1024 * 1024 &&
                      request.resource.contentType.matches('image/.*');
    }

    // Profile pictures - original naming scheme (profile_userId.jpg)
    match /profile_pictures/profile_{userId}.jpg {
      // Allow authenticated users to read any profile picture
      allow read: if request.auth != null;

      // Allow users to upload/update their own profile picture
      allow write: if request.auth != null &&
                      userId == request.auth.uid &&
                      request.resource.size < 5 * 1024 * 1024 &&
                      request.resource.contentType.matches('image/.*');
    }

    // General profile_pictures directory access
    match /profile_pictures/{allPaths=**} {
      // Allow authenticated users to read profile pictures
      allow read: if request.auth != null;

      // Block broad writes so users cannot overwrite each other's images.
      // Uploads must match one of the owner-validated patterns above.
      allow write: if false;
    }

    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
